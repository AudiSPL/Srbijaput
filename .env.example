# ═══════════════════════════════════════════════════════════
# Fleet Fuel Dashboard — Environment Variables
# ═══════════════════════════════════════════════════════════
# Kopiraj ovaj fajl u .env.local i popuni vrednosti

# Google Sheet CSV export URL
# Format: https://docs.google.com/spreadsheets/d/{SHEET_ID}/export?format=csv&gid=0
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/1taPBLXDC4KEjyzQ5K8lJ_amB15Fa0azraEc_XEcaa_E/export?format=csv&gid=0

# Tajni token za revalidation endpoint (opciono ali preporučljivo)
# Generiši sa: openssl rand -hex 32
REVALIDATE_SECRET=tvoj_tajni_token_ovde
